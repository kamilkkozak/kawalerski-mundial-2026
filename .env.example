# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — TYLKO po stronie serwera (cron, admin). NIE z prefiksem NEXT_PUBLIC!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- football-data.org (darmowy klucz API) ---
FOOTBALL_DATA_API_KEY=your-football-data-token

# --- Cron (chroni endpoint /api/cron/sync-results) ---
# Wygeneruj losowy ciąg, ten sam podaj w Vercel Cron jako nagłówek Authorization: Bearer <secret>
CRON_SECRET=change-me-to-a-long-random-string

# --- Logowanie po nazwie użytkownika ---
# Sekret, z którego wyliczane jest hasło Supabase (nazwa -> HMAC). Ustaw raz i NIGDY nie zmieniaj
# (zmiana = wszyscy tracą dostęp do kont). Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=change-me-to-a-long-random-string

# Bazowy URL aplikacji (do redirectu magic link). Lokalnie: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
